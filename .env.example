# ── Base de datos MySQL (WordPress/Bookly) ─────────────────────────────────
# El contenedor accede a MySQL del VPS via host.docker.internal
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=bd_name
DB_USER=bd_user
DB_PASSWORD=CAMBIA_ESTO
DB_PREFIX=prefixdb_

# ── Proveedor LLM ──────────────────────────────────────────────────────────
# Opciones: anthropic | openai
LLM_PROVIDER=openai

# Modelo (opcional — si no se indica se usa el por defecto)
# OpenAI    → gpt-4o-mini
# Anthropic → claude-sonnet-4-6
# LLM_MODEL=gpt-4o-mini

# ── API Keys ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── App ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://tudominio.com
